# SmartAM_System 环境配置模板
# 复制此文件为 .env 并修改为你的实际配置

# ============================================
# 相机配置
# ============================================

# IDS 相机配置
IDS_CAMERA_ENABLED=true
IDS_CAMERA_INDEX=0
IDS_CAMERA_WIDTH=640
IDS_CAMERA_HEIGHT=480
IDS_CAMERA_FPS=30

# 旁轴摄像头配置（罗技 USB 摄像头）
SIDE_CAMERA_ENABLED=true
SIDE_CAMERA_INDEX=1
SIDE_CAMERA_WIDTH=1280
SIDE_CAMERA_HEIGHT=720
SIDE_CAMERA_FPS=30

# Fotric 红外相机配置
FOTRIC_ENABLED=true
FOTRIC_IP=192.168.1.100
FOTRIC_PORT=10080
FOTRIC_TEMP_MIN=20.0
FOTRIC_TEMP_MAX=300.0

# ============================================
# OctoPrint 打印机配置
# ============================================

OCTOPRINT_ENABLED=true
OCTOPRINT_URL=http://127.0.0.1:5000
OCTOPRINT_API_KEY=your_api_key_here

# 串口配置（备用）
PRINTER_SERIAL_PORT=COM3
PRINTER_BAUDRATE=115200

# ============================================
# PacNet 模型配置
# ============================================

# 模型文件路径（相对于 backend 目录）
MODEL_PATH=weights/model_full.pt
SCALER_PATH=weights/scaler.pkl

# 推理设备: auto / cpu / cuda
INFERENCE_DEVICE=auto

# 推理频率 (Hz)
INFERENCE_RATE=5

# 输入图像尺寸
INPUT_WIDTH=224
INPUT_HEIGHT=224

# ============================================
# 闭环控制配置
# ============================================

# 控制模式: disabled / manual / auto
CONTROL_MODE=manual

# 状态序列缓冲区配置
BUFFER_SIZE=10
FORGETTING_FACTOR=0.8

# 双阈值施密特触发配置
THRESHOLD_ON=0.7
THRESHOLD_OFF=0.4

# 控制间隔（秒）
CONTROL_INTERVAL=1.0

# PID 参数（温度控制）
PID_KP=0.5
PID_KI=0.05
PID_KD=0.02
TARGET_TEMP=200.0

# ============================================
# 数据采集配置
# ============================================

# DAQ 采样率 (Hz)
DAQ_SAMPLE_RATE=10

# 数据保存目录
DATA_SAVE_DIR=../data

# 自动保存间隔（秒，0 表示不自动保存）
AUTO_SAVE_INTERVAL=60

# ============================================
# 服务配置
# ============================================

# API 服务配置
API_HOST=0.0.0.0
API_PORT=8000

# 日志级别: debug / info / warning / error
LOG_LEVEL=info

# 日志文件路径（留空则只输出到控制台）
LOG_FILE=logs/smartam.log

# 是否启用调试模式
DEBUG=false

# 是否启用热重载（开发环境）
RELOAD=false

# ============================================
# 前端配置
# ============================================

# 前端 URL（用于 CORS）
FRONTEND_URL=http://localhost:5173

# 是否允许所有跨域（仅开发环境）
CORS_ALLOW_ALL=false

# ============================================
# 安全配置
# ============================================

# JWT 密钥（生产环境必须修改）
JWT_SECRET_KEY=your-secret-key-change-this-in-production

# JWT 令牌过期时间（分钟）
JWT_EXPIRE_MINUTES=60

# API 访问令牌（可选，用于简单的 API 认证）
API_TOKEN=

# ============================================
# 高级配置
# ============================================

# 视频流质量 (1-100)
VIDEO_QUALITY=85

# 视频流帧率限制 (fps)
VIDEO_FPS=30

# WebSocket 心跳间隔（秒）
WS_HEARTBEAT_INTERVAL=30

# 最大并发连接数
MAX_CONNECTIONS=100

# 数据保留天数（自动清理旧数据）
DATA_RETENTION_DAYS=30
