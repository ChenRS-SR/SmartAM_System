# SmartAM System 后端配置文件
# 复制此文件为 .env 并修改配置

# ========== OctoPrint 配置 ==========
OCTOPRINT_URL=http://127.0.0.1:5000
OCTOPRINT_API_KEY=your_api_key_here

# ========== 相机配置 ==========
# IDS 相机
IDS_ENABLE=true
IDS_EXPOSURE=8000.0
IDS_GAIN=1.0

# 旁轴相机
SIDE_CAMERA_ENABLE=true
SIDE_CAMERA_INDEX=1

# Fotric 红外相机
FOTRIC_ENABLE=true
FOTRIC_IP=192.168.1.100
FOTRIC_PORT=10080

# ========== 模拟模式配置 ==========
# 启用模拟模式（无需硬件即可调试）
SIMULATION_MODE=false

# 硬件连接失败时自动切换到模拟模式
SIMULATION_AUTO_FALLBACK=true

# ========== 采集配置 ==========
# 采集帧率 (fps)
CAPTURE_FPS=2.0

# 保存目录
SAVE_DIRECTORY=../data

# ========== 调试配置 ==========
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
