@echo off
chcp 65001 >nul
echo ==========================================
echo 网络连接诊断
echo ==========================================
echo.

echo [1] 本机网络配置:
echo ------------------------------------------
ipconfig | findstr /i "ipv4 子网 网关"
echo.

echo [2] 路由表:
echo ------------------------------------------
route print | findstr "0.0.0.0"
echo.

echo [3] 检查常见工业设备 IP:
echo ------------------------------------------
set "common_ips=192.168.1.100 192.168.1.10 192.168.1.1 192.168.0.100 192.168.0.10 10.0.0.100 172.16.0.100"
for %%i in (%common_ips%) do (
    ping -n 1 -w 500 %%i | findstr /i "ttl" >nul && (
        echo [OK] %%i 在线
    ) || (
        echo [X] %%i 无响应
    )
)
echo.

echo [4] ARP 表 (已连接设备):
echo ------------------------------------------
arp -a | findstr /v "接口"
echo.

echo ==========================================
echo 诊断完成
echo ==========================================
pause
