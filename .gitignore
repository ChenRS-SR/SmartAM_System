# ============================================
# SmartAM_System - Git Ignore
# ============================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Environment variables
.env
.env.local
.env.*.local
!.env.example

# Logs
*.log
logs/
log/

# Data directories (generated during runtime)
data/
backend/data/
backend/snapshots/
backend/ids_focus_test_*/
backend/test_data/
backend/test_images/

# Model weights (large files)
backend/weights/*.pt
backend/weights/*.pkl
backend/weights/*.onnx
!backend/weights/.gitkeep

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Frontend build output
frontend/dist/
frontend/dist-ssr/
*.local

# Test outputs
test_output/
coverage/
.pytest_cache/
htmlcov/
.tox/

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# OS generated files
Thumbs.db
.DS_Store
*.lnk

# Docker
.dockerignore
docker-compose.override.yml

# Specific to this project
diagnose_octoprint.py
test_printer_api.py
test_websocket.py
*.spec
